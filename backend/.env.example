# ==========================================================
# UniSense — Environment Configuration
# .env asla commit edilmez (.gitignore içinde)
# ==========================================================

# --- Uygulama ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002
APP_LOG_LEVEL=INFO

# --- LLM: Gemini ---
# Birden fazla key (virgülle ayır) → quota dolunca otomatik diğerine geçer
# Tek key kullanacaksan GEMINI_API_KEY satırını doldur, üsttekini boş bırak
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FAST=gemini-2.5-flash-lite
GEMINI_MODEL_QUALITY=gemini-2.5-flash

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/embeddings/chromadb
CHROMA_COLLECTION=unisense
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Güvenlik ---
SECURITY_REQUIRE_API_KEY=false
SECURITY_API_KEYS=
RATE_LIMIT_ASK=20
CORS_ALLOWED_ORIGINS=https://unisense.vercel.app,http://localhost:5173,http://localhost:5174
AUDIT_LOG_PATH=./logs/audit.log

# --- Dış servisler (veri kaynakları) ---
YOK_ATLAS_BASE=https://yokatlas.yok.gov.tr
OSYM_BASE=https://www.osym.gov.tr
URAP_BASE=https://www.urapcenter.org
