// UniSense — Firestore Security Rules
//
// Deploy: CI workflow (.github/workflows/firebase-rules.yml) otomatik yapar,
// ya da manuel: npx firebase-tools deploy --only firestore:rules
//
// Mantık:
//   1. Her kullanıcı SADECE kendi users/{uid}/** alanına erişir.
//   2. Yazılan dokümanlar alan sayısı + string uzunluğu ile sınırlandırılır —
//      sahiplik doğru olsa bile bir kullanıcının sınırsız veri yazıp
//      Firestore faturası şişirmesi engellenir.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function fieldCountMax(n) {
      return request.resource.data.size() <= n;
    }

    // Alan varsa string tipinde ve uzunluğu sınırda olmalı
    function strMax(field, n) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string
            && request.resource.data[field].size() <= n);
    }

    // Kullanıcı profil dokümanı
    match /users/{uid} {
      allow read, delete: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && fieldCountMax(12)
        && strMax('displayName', 100)
        && strMax('email', 200)
        && strMax('photoURL', 1000);

      // Tercih listesi (max 24 sıra — sayı sınırı client'ta, boyut sınırı burada)
      match /tercih/{code} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(18)
          && strMax('note', 500)
          && strMax('department_name', 300)
          && strMax('university_name', 300)
          && strMax('city', 100);
      }

      // DGS tercih listesi (max 30)
      match /dgs_tercih/{programKodu} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('program_adi', 400)
          && strMax('university_name', 300)
          && strMax('city', 100);
      }

      // KPSS tercih listesi (max 30 — sayı sınırı client'ta, boyut burada)
      match /kpss_tercih/{kadroKodu} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('kurum', 300)
          && strMax('unvan', 200)
          && strMax('il', 100);
      }

      // TUS uzmanlık tercih listesi (max 30)
      match /tus_tercih/{programKodu} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('dal', 200)
          && strMax('kurum', 400)
          && strMax('kontenjan_turu', 60);
      }

      // DUS uzmanlık tercih listesi (max 30)
      match /dus_tercih/{programKodu} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('dal', 200)
          && strMax('kurum', 400)
          && strMax('kontenjan_turu', 60);
      }

      // LGS lise tercih listesi (max 25)
      match /lgs_tercih/{liseKey} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('okul', 300)
          && strMax('il', 100)
          && strMax('ilce', 100)
          && strMax('tur', 60)
          && strMax('dil', 100);
      }

      // Konu takip ilerlemesi — sınav başına 1 doküman (checked haritası).
      // Doküman ID'si 4 sınavla sınırlı → sınırsız doküman üretimi engellenir.
      match /konu_ilerleme/{sinav} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && sinav in ['YKS', 'KPSS', 'DGS', 'LGS']
          && fieldCountMax(3);
      }

      // Günlük aktivite / seri (streak) — tek "gunluk" dokümanı
      match /aktivite/{doc} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(6)
          && strMax('lastDate', 20);
      }

      // Push (FCM) token'ları — doküman ID = token (cihaz başına tek kayıt).
      // Gönderici cron admin SDK ile okur (kuralları atlar); client kendi token'ını yazar.
      match /pushTokens/{token} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(4)
          && strMax('token', 400)
          && strMax('ua', 300);
      }

      // Yanlış Defteri — her yanlış 1 doküman (metin; foto Storage/Blaze gerektirir, yok)
      match /yanlislar/{id} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('ders', 40)
          && strMax('konu', 120)
          && strMax('soru', 1000)
          && strMax('neden', 1000)
          && strMax('sinav', 8)
          && strMax('nextReview', 20);
      }

      // Bilgi kartları (flashcard) — düz model: her kart 1 doküman, deste alanıyla gruplu
      match /kartlar/{id} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(12)
          && strMax('deste', 80)
          && strMax('on', 500)
          && strMax('arka', 1000)
          && strMax('nextReview', 20);
      }

      // Deneme günlüğü — her deneme 1 doküman (ders net haritası + puan/sıra)
      match /denemeler/{id} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(14)
          && strMax('sinav', 8)
          && strMax('type', 8)
          && strMax('ad', 120)
          && strMax('tarih', 20);
      }

      // Sorgu geçmişi — sadece ekleme + okuma + silme (değiştirilemez log)
      match /queries/{qid} {
        allow read, delete: if isOwner(uid);
        allow create: if isOwner(uid)
          && fieldCountMax(8)
          && strMax('query', 600)
          && strMax('response_preview', 600);
      }

      // Sohbet oturumları (max 5/kişi — FIFO client'ta)
      match /sessions/{sid} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && fieldCountMax(8)
          && strMax('title', 100);

        match /messages/{mid} {
          allow read, delete: if isOwner(uid);
          allow create: if isOwner(uid)
            && fieldCountMax(10)
            && strMax('text', 10000);
        }
      }
    }

    // Herhangi bir başka koleksiyona genel erişim YOK
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
