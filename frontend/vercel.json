{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "uni-sense.vercel.app" }],
      "destination": "https://www.unisense.site/:path*",
      "permanent": true
    },
    { "source": "/home", "destination": "/anasayfa", "permanent": true },
    { "source": "/search", "destination": "/arama", "permanent": true },
    { "source": "/recommend", "destination": "/oneriler", "permanent": true },
    { "source": "/login", "destination": "/giris", "permanent": true },
    { "source": "/profile", "destination": "/profil", "permanent": true },
    { "source": "/privacy", "destination": "/gizlilik", "permanent": true },
    { "source": "/compare", "destination": "/karsilastir", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
