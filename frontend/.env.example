# UniSense Frontend Environment Variables
# .env.local olarak kopyala (git ignore'da)
# Firebase Console → Project Settings → General → Your apps → Web app

VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# App Check (reCAPTCHA v3) — botların Firestore'a raw-SDK/REST ile doğrudan
# erişimini engeller. Firebase Console → App Check → Web app'i reCAPTCHA v3 ile
# kaydet → verilen SITE KEY'i buraya yaz. BOŞ bırakılırsa App Check devre dışı
# (lokal dev çalışır). Prod'da doldur + konsolda Firestore için "Enforce" aç.
VITE_RECAPTCHA_SITE_KEY=

# Backend URL (development: localhost, production: deploy URL'in)
VITE_API_URL=http://localhost:8002
