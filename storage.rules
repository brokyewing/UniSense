// UniSense — Firebase Storage Security Rules
//
// Deploy: CI workflow (.github/workflows/firebase-rules.yml) otomatik yapar,
// ya da manuel: npx firebase-tools deploy --only storage
//
// NOT: Kod avatars/{uid}/... yoluna yükler (frontend/src/firebase.js →
// uploadAvatar). Kural yolu ile kod yolu AYNI olmalı, yoksa yükleme reddedilir.
//
//   - Kullanıcı yalnızca kendi avatars/{uid}/ klasörüne yazabilir
//   - Max 5 MB (client kontrolüyle aynı), sadece png/jpeg/webp
//     (SVG bilerek YOK — içine script gömülebilir)

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /avatars/{uid}/{fileName} {
      // Avatarlar profil fotoğrafı olarak herkese gösterilebilir
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(png|jpeg|webp)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Diğer her şeyi reddet
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
